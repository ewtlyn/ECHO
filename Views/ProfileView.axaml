<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ECHO.Views.ProfileView"
             Background="#121314">

    <Grid RowDefinitions="Auto,Auto,Auto,*"
          Margin="24,26,24,26">

        <Button Grid.Row="0"
                Content="LogOut"
                HorizontalAlignment="Right"
                Background="Transparent"
                BorderThickness="0"
                Foreground="#A970FF"
                FontSize="16"
                Click="LogOut_Click"/>
        
        <Button Grid.Row="0"
                Content="+ New post"
                Height="44"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                HorizontalAlignment="Right"
                Margin="0,0,90,0"
                Background="#8B5CF6"
                Foreground="White"
                BorderThickness="0"
                CornerRadius="10"
                Padding="14,8"
                Click="NewPost_Click"/>

        <TextBlock Grid.Row="0"
                   Text="Your profile"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="White"/>

        <Border Grid.Row="1"
                Height="1"
                Background="#1C1D22"
                Margin="0,18,0,18"/>

        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*"
              Margin="0,0,0,22">

            <Border Width="110"
                    Height="110"
                    CornerRadius="55"
                    Background="#E6E6E6"
                    ClipToBounds="True">
                <Image x:Name="AvatarImage"
                       Stretch="UniformToFill"/>
            </Border>

            <StackPanel Grid.Column="1"
                        Margin="22,18,0,0"
                        Spacing="8">
                <TextBlock x:Name="UsernameText"
                           Text="Username"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                <TextBlock x:Name="CreatedAtText"
                           Text="Дата регистрации"
                           FontSize="13"
                           Foreground="#8D8D98"/>

                <TextBlock x:Name="PostsCountText"
                           Text="Posts: 0"
                           FontSize="13"
                           Foreground="#8D8D98"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="3" Spacing="16">
            <Border Height="1"
                    Background="#1C1D22"/>

            <StackPanel Margin="12,10,0,0"
                        Spacing="4">
                <TextBlock Text="Your posts"
                           FontSize="16"
                           Foreground="White"/>
                <Border Width="80"
                        Height="2"
                        Background="#8B5CF6"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="PostsPanel"
                            Margin="12,10,0,0"
                            Spacing="16"/>
            </ScrollViewer>
        </StackPanel>
    </Grid>
</UserControl>