<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="420" d:DesignHeight="520"
        x:Class="ECHO.Views.SaveToBoardWindow"
        Title="AddToAlbumWindow"
        Background="#121314">
        
        <Grid RowDefinitions="Auto, *, Auto"
              Margin="24">
                
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="Add to album"
                           FontSize="22"
                           Foreground="White"/>
                <Border Height="1" Background="#1F2025"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,18,0,18">
                <StackPanel x:Name="AlbumsPanel" Spacing="12"/>
            </ScrollViewer>

            <TextBlock Grid.Row="2"
                       x:Name="ErrorText"
                       Foreground="#FF6B6B"
                       FontSize="13"/>
        </Grid>
</Window>
