<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d"
        x:Class="ECHO.MainWindow"
        Title="ECHO"
        Width="1180"
        Height="760"
        MinWidth="1000"
        MinHeight="620"
        Background="#090A0D"
        d:DesignWidth="1180"
        d:DesignHeight="760">

    <Grid RowDefinitions="3,*">
        
        <Grid Grid.Row="1" ColumnDefinitions="250,*">

            <!-- ЛЕВАЯ СТОРОНА -->
            <Border Grid.Column="0"
                    Background="#090A0D"
                    BorderBrush="#202122"
                    BorderThickness="0,0,1,0"
                    Padding="28,28,18,28">

                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    
                    <TextBlock Text="ECHO"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <StackPanel Grid.Row="1"
                                Margin="0,36,0,0"
                                Spacing="14">

                        <Button Name="HomeButton"
                                Click="HomeButton_Click"
                                Background="#312A50"
                                BorderThickness="0"
                                CornerRadius="12"
                                Height="52"
                                Width="170"
                                HorizontalContentAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="14" Margin="22,0,0,0">
                                <materialIcons:MaterialIcon Kind="Home"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="#9E79FF"/>
                                <TextBlock Text="Home"
                                           FontSize="18"
                                           Foreground="#9E79FF"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Name="GalleryButton"
                                Click="GalleryButton_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Height="52"
                                Width="170"
                                HorizontalContentAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="14" Margin="22,0,0,0">
                                <materialIcons:MaterialIcon Kind="Image"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="#7C7C86"/>
                                <TextBlock Text="Gallery"
                                           FontSize="18"
                                           Foreground="#7C7C86"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Name="ProfileButton"
                                Click="ProfileButton_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="12"
                                Height="52"
                                Width="170"
                                HorizontalContentAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" Spacing="14" Margin="22,0,0,0">
                                <materialIcons:MaterialIcon Kind="Account"
                                                             Width="22"
                                                             Height="22"
                                                             Foreground="#7C7C86"/>
                                <TextBlock Text="Profile"
                                           FontSize="18"
                                           Foreground="#7C7C86"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ПРАВАЯ СТОРОНА -->
            <ContentControl x:Name="MainContent"
                            Grid.Column="1"/>
        </Grid>
    </Grid>
</Window>